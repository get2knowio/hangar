# =============================================================================
# Hangar — environment configuration
#
# Copy this file to `deploy/.env` and edit. Every value is supplied via the
# environment (Constitution V: no in-app config UI). All app settings use the
# HANGAR_ prefix. Lines with safe defaults are commented out; uncomment to
# override.
#
#   cp deploy/.env.example deploy/.env
#
# =============================================================================

# -----------------------------------------------------------------------------
# Access mode (FR-027–FR-031, Constitution III — NON-NEGOTIABLE)
# -----------------------------------------------------------------------------

# Choose ONE access mode. Hangar is FAIL-CLOSED: if no mode is chosen the app
# refuses to start and tells you to choose (FR-029).
#   forward-auth -> trust an identity header injected by a reverse proxy.
#   oidc         -> app-native OpenID Connect login (see the OIDC block below).
#   disabled     -> no auth gate (homelab/network-trust only); loud startup
#                   warning; refuses a public bind without HANGAR_ALLOW_PUBLIC_BIND.
#HANGAR_ACCESS_MODE=forward-auth

# Legacy selector (still honored when HANGAR_ACCESS_MODE is unset):
#   enabled  -> forward-auth ; disabled -> disabled
HANGAR_FORWARD_AUTH=enabled

# Identity header the proxy injects after authenticating the user.
# Default: Remote-User. Authentik forward-auth typically sends X-authentik-username.
HANGAR_FORWARD_AUTH_USER_HEADER=Remote-User
#HANGAR_FORWARD_AUTH_USER_HEADER=X-authentik-username

# Optional: pin Hangar to a single identity. If set, only this username is
# admitted even if the proxy authenticates others.
#HANGAR_FORWARD_AUTH_ALLOWED_USER=you@example.com

# Anti-spoofing: the identity header is trusted ONLY when the request arrives
# from inside this CIDR (i.e. from your reverse proxy) (FR-030). For Docker
# bridge/overlay networks 172.16.0.0/12 is the usual range; tighten if you can.
HANGAR_TRUSTED_PROXY_CIDR=172.16.0.0/12

# Optional alternative/addition to the CIDR check: a shared secret the proxy
# must send as the header `X-Hangar-Proxy-Secret`. Generate a random value.
#HANGAR_TRUSTED_PROXY_SECRET=change-me-to-a-long-random-string

# Refuse to bind a non-private/public interface unless this is explicitly set
# (FR-030). Leave UNSET for the safe default (internal/loopback bind only).
#HANGAR_ALLOW_PUBLIC_BIND=1

# Audit actor recorded for actions when running in `disabled` mode (there is no
# authenticated identity to attribute). Default: local-operator.
HANGAR_OPERATOR=local-operator

# -----------------------------------------------------------------------------
# OIDC login (only when HANGAR_ACCESS_MODE=oidc)
# -----------------------------------------------------------------------------
# Register Hangar as a CONFIDENTIAL client at your IdP (Authentik/Keycloak/…),
# with redirect URI https://hangar.${HANGAR_DOMAIN}/auth/callback.

#HANGAR_OIDC_ISSUER=https://auth.example.com/application/o/hangar/
#HANGAR_OIDC_CLIENT_ID=hangar
#HANGAR_OIDC_CLIENT_SECRET=change-me
# Recommended behind a TLS proxy (else derived from request; needs --proxy-headers):
#HANGAR_OIDC_REDIRECT_URL=https://hangar.example.com/auth/callback
#HANGAR_OIDC_SCOPES=openid email profile
# Which claim becomes the audit actor (default: email).
#HANGAR_OIDC_USERNAME_CLAIM=email
# Optional allowlist — admit any authenticated user when both are empty.
#HANGAR_OIDC_ALLOWED_USERS=you@example.com,teammate@example.com
#HANGAR_OIDC_ALLOWED_GROUPS=hangar-admins
#HANGAR_OIDC_GROUPS_CLAIM=groups
# Optional RP-initiated logout target at the IdP.
#HANGAR_OIDC_POST_LOGOUT_REDIRECT_URL=https://hangar.example.com/

# Session cookie (oidc mode). Signing key: a dedicated secret, else reuses
# HANGAR_SECRET_KEY. Set _SECURE=false ONLY for local http:// development.
#HANGAR_SESSION_SECRET=change-me-to-a-long-random-string
#HANGAR_SESSION_MAX_AGE_SECONDS=28800
#HANGAR_SESSION_COOKIE_SECURE=true
# Name of the session cookie (rarely changed). Default: hangar_session.
#HANGAR_SESSION_COOKIE_NAME=hangar_session

# -----------------------------------------------------------------------------
# Credential encryption (FR-032)
# -----------------------------------------------------------------------------

# REQUIRED for real provider connections. Fernet key used to encrypt provider
# credentials (GitHub App private key, webhook secrets, tokens) at rest.
# Generate one with:
#   python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
HANGAR_SECRET_KEY=

# -----------------------------------------------------------------------------
# "Connect with GitHub" — one-click GitHub App provisioning (#25)
# -----------------------------------------------------------------------------

# The instance's browser-visible base URL. Used to build the GitHub App manifest's
# redirect/setup callback URLs for the "Connect with GitHub" flow. The callbacks are
# BROWSER redirects (GitHub never connects inbound), so a LAN/VPN URL is valid and the
# flow works on a non-internet-facing install. When unset it is derived from the request
# (set it explicitly behind a TLS-terminating proxy, like HANGAR_OIDC_REDIRECT_URL).
# Enterprise hosts (GHES https://ghe.example.com, GHEC https://acme.ghe.com) are chosen
# per-connection in the Add-connection dialog — no global host setting is needed. A
# self-hosted Gitea instance URL is likewise a per-connection field (base_url), not an env
# var; HANGAR_BASE_URL is only the GitHub App manifest callback host.
#HANGAR_BASE_URL=https://hangar.example.com

# Make the auto-provisioned GitHub App installable on your ORGANIZATIONS, not just your
# personal account (one Hangar connection per org). Default is `false`, which registers the
# App as PRIVATE — installable only on the account that owns it, so you can pick repos from
# your personal account alone. Set `true` BEFORE running "Connect with GitHub" so the newly
# created App is registered public. ("Public" only means installable beyond the owner
# account; it is NOT Marketplace-listed, and Hangar still solely holds the App's private
# key.) Applies to newly created Apps only — flip an existing App in its GitHub settings.
#HANGAR_GITHUB_APP_PUBLIC=true

# -----------------------------------------------------------------------------
# Webhooks (FR-033)
# -----------------------------------------------------------------------------

# HMAC secret shared with the provider so inbound webhooks can be verified —
# GitHub's X-Hub-Signature-256 (sha256=<hex>) or Gitea's X-Gitea-Signature (raw hex),
# both HMAC-SHA256 over the body. Inbound webhooks are REFUSED (fail-closed) until this is
# set. Optional — the poller keeps snapshots fresh without webhooks; set it for push-time
# updates.
#HANGAR_WEBHOOK_SECRET=change-me-to-a-long-random-string

# -----------------------------------------------------------------------------
# Networking / runtime
# -----------------------------------------------------------------------------

# Bind host/port the app uses for its own startup safety checks. Inside the
# container the process binds 0.0.0.0; the host only publishes the port on
# 127.0.0.1 (see docker-compose.yml). Defaults: 127.0.0.1 / 8000.
#HANGAR_HOST=127.0.0.1
#HANGAR_PORT=8000

# Directory of the built SPA served at /. The container image sets this to
# /app/static and ships the SPA there — do NOT override it in a container.
#HANGAR_STATIC_DIR=/app/static

# -----------------------------------------------------------------------------
# Persistence
# -----------------------------------------------------------------------------

# Default is SQLite on the mounted /data volume (in the image) — leave everything
# below unset to keep it.
#
# To use Postgres, set the discrete HANGAR_POSTGRES_* vars below. Setting
# HANGAR_POSTGRES_HOST switches Hangar to Postgres and TAKES PRECEDENCE over
# HANGAR_DATABASE_URL (so the image's SQLite default is overridden). HOST +
# PASSWORD is the minimal config; the rest default to the bundled service.
#HANGAR_POSTGRES_HOST=postgres
#HANGAR_POSTGRES_PASSWORD=hangar
#HANGAR_POSTGRES_PORT=5432
#HANGAR_POSTGRES_DB=hangar
#HANGAR_POSTGRES_USER=hangar
# libpq sslmode forwarded to asyncpg (require/verify-ca/verify-full/prefer/…):
#HANGAR_POSTGRES_SSLMODE=require

# Advanced escape hatch — a full SQLAlchemy URL (used only when HANGAR_POSTGRES_HOST is unset):
#HANGAR_DATABASE_URL=postgresql+asyncpg://hangar:hangar@postgres:5432/hangar
#HANGAR_DATABASE_URL=sqlite+aiosqlite:///./hangar.db

# Credentials for the optional bundled Postgres service (compose `postgres`
# profile). Only used if you run with `--profile postgres`. Keep these in sync
# with the HANGAR_POSTGRES_* values above (e.g. set
# HANGAR_POSTGRES_PASSWORD=${POSTGRES_PASSWORD}).
#POSTGRES_USER=hangar
#POSTGRES_PASSWORD=hangar
#POSTGRES_DB=hangar

# -----------------------------------------------------------------------------
# Sync / poller (Constitution VI)
# -----------------------------------------------------------------------------

# How often the per-connection poller refreshes snapshots, in seconds.
# Default: 300 (5 min). ETag-conditional + webhook-driven, so this is a ceiling.
#HANGAR_POLL_INTERVAL_SECONDS=300

# Age, in seconds, after which a cached snapshot is shown as "stale" in the UI.
# Default: 900 (15 min).
#HANGAR_STALE_AFTER_SECONDS=900

# Per-request HTTP timeout for provider calls, in seconds. Bounds how long one hung
# GitHub request can hold up the poll cycle. Default: 30.
#HANGAR_GITHUB_HTTP_TIMEOUT_SECONDS=30

# Max concurrent provider sub-requests issued while interrogating a single repo.
# Lower it if you hit GitHub's secondary (concurrency) rate limit. Default: 8.
#HANGAR_GITHUB_MAX_CONCURRENCY=8

# Load the sample fixtures on first boot. Default is `false` — production runs
# against real provider connections (add a GitHub App connection on the Providers
# screen). Set `true` only to explore the UI with sample data offline.
HANGAR_SEED_DEMO_DATA=false

# -----------------------------------------------------------------------------
# Deployment (consumed by the compose files, NOT by the app itself)
# -----------------------------------------------------------------------------

# Base domain for the Traefik router rule -> hangar.${HANGAR_DOMAIN}
# (only used by the production docker-compose.yml)
HANGAR_DOMAIN=example.com

# Published image for the adopter example (docker-compose.example.yml). Pin to a
# release tag for reproducible deploys; :latest tracks the newest release.
#HANGAR_IMAGE=ghcr.io/get2knowio/hangar:0.1.0
