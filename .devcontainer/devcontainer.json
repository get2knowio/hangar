{
    "name": "Python Agentic Development",
    "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
    "features": {
        "ghcr.io/devcontainers/features/python:1": {},
        "ghcr.io/devcontainers/features/node:1": {
            "version": "22"
        },
        "ghcr.io/devcontainers/features/docker-in-docker:2": {
            "version": "latest",
            "enableNonRootDocker": "true",
	    "moby": "false"
        },
        "ghcr.io/devcontainers/features/aws-cli:1": {},
        "ghcr.io/devcontainers/features/github-cli:1": {},
        "ghcr.io/eitsupi/devcontainer-features/jq-likes:2": {},
        "ghcr.io/get2knowio/devcontainer-features/ai-clis:2": {
	    "omit": "codeRabbit,beads"
	},
        // install/omit: claudeCode, geminiCli, codex, copilot, openCode, codeRabbit, beads, specifyCli
        "ghcr.io/get2knowio/devcontainer-features/modern-cli-tools:2": {},
        // install/omit: bat, ripgrep, fd, fzf, eza, zoxide, neovim, tmux, lazygit, astGrep, jujutsu, zellij, starship
        "ghcr.io/get2knowio/devcontainer-features/python-tools:2": {
	    "omit": "poetry"
	},
        // install/omit: uv, poetry, ruff, mypy
        "ghcr.io/get2knowio/devcontainer-features/github-actions-tools:2": {}
        // install/omit: act, actionlint
    },
    "customizations": {
        "vscode": {
            "settings": {
                "terminal.integrated.defaultProfile.linux": "zsh"
            }
        }
    },
    "postCreateCommand": "python3 --version && node --version"
}
